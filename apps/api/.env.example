# ─────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────
# Database — PostgreSQL (Railway)
# ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/whatsell

# ─────────────────────────────────────────────────
# Redis — BullMQ + Cache (Railway)
# ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────
# JWT Authentication
# access token : 15min | refresh token : 7j avec rotation
# ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────
# Cloudflare R2 — Stockage objets (compatible AWS S3)
# Buckets : receipts, logos, invoices
# ─────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_RECEIPTS=whatsell-receipts
R2_BUCKET_LOGOS=whatsell-logos
R2_BUCKET_INVOICES=whatsell-invoices

# ─────────────────────────────────────────────────
# Twilio — WhatsApp Business API
# ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─────────────────────────────────────────────────
# LLM — API OpenAI (ou équivalent)
# Timeout : 3 min max — fallback obligatoire si dépassé
# ─────────────────────────────────────────────────
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ─────────────────────────────────────────────────
# Sentry — Monitoring & Error tracking
# ─────────────────────────────────────────────────
SENTRY_DSN=

# ─────────────────────────────────────────────────
# Chiffrement AES-256-GCM — tokens WhatsApp + clés API tiers
# Doit faire exactement 32 caractères
# ─────────────────────────────────────────────────
ENCRYPTION_KEY=your-32-character-encryption-key!!

# ─────────────────────────────────────────────────
# Web Push Notifications — VAPID keys
# Générer avec : node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
# ─────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@whatsell.io
